# 复制为 deploy/.env 后按需修改
# cp deploy/env.example deploy/.env

# 宿主机映射端口（Arduino SERVER_URL 需指向服务器 IP:此端口）
SPROUT_PORT=5000

# 接口测试目标（backend/tests/test_dialogue_api.py 使用）
# local：Flask 内存测试；remote：HTTP 请求下方地址
TEST_MODE=local
SPROUT_SERVER_URL=http://127.0.0.1:5000

# 百炼 TTS（可选；不配置则跳过语音合成）
DASHSCOPE_API_KEY=
DASHSCOPE_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_TTS_MODEL=cosyvoice-v3-flash
DASHSCOPE_TTS_VOICE=longanyang

# 百炼 LLM 对话（POST /plant 文案生成）
DASHSCOPE_LLM_MODEL=qwen-plus
